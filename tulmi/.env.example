# This file is a slim pointer — the canonical, fully-commented template lives
# at the repo root ../.env.example. Keep them in sync: docker-compose reads
# tulmi/.env via env_file, so during deploy:
#
#   cp ../.env.example tulmi/.env  &&  $EDITOR tulmi/.env
#
# Only the variables actually exported below are picked up by the server; the
# canonical template explains each one in detail.

NODE_ENV=production

STT_PROVIDER=openai
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Live dictation (WS /v1/transcribe-stream). Optional — leave blank to disable
# live mode; the app's one-shot /v1/transcribe-clean fallback still works.
DEEPGRAM_API_KEY=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Leave at false unless you are running test-pipeline.ts locally. The server
# refuses to boot with DEV_SKIP_AUTH=true under NODE_ENV=production.
DEV_SKIP_AUTH=false
