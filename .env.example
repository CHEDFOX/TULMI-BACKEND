# =====================================================================
# Tulmi — environment variables (canonical template)
# Copy this file to `tulmi/.env` and fill in real values.
# NEVER commit the real .env. Secrets live ONLY in env vars.
# =====================================================================

# --- Speech-to-Text provider ---
# "openai" (default, ~100 languages — best for a global product) or "groq".
STT_PROVIDER=openai

# OpenAI STT (used when STT_PROVIDER=openai). Get a key:
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# gpt-4o-transcribe (best), gpt-4o-mini-transcribe (cheaper), or whisper-1 (legacy).
OPENAI_STT_MODEL=gpt-4o-transcribe

# Groq STT (only needed if STT_PROVIDER=groq) — fast + cheap Whisper.
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3-turbo

# Deepgram (live dictation only — the WS /v1/transcribe-stream route).
# The one-shot REST /v1/transcribe-clean uses STT_PROVIDER above instead.
# Get a key: https://console.deepgram.com/. Leave blank to disable live mode;
# the app's REST fallback still works.
DEEPGRAM_API_KEY=

# --- OpenRouter (cleanup LLM) ---
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Default cleanup model. Swap this ONE line to change models — no code edits.
# Default: fast + cheap + strong multilingual.
CLEANUP_MODEL=openai/gpt-5.4-mini

# --- Text-to-speech (voice output; uses OPENAI_API_KEY) ---
# Used when the app speaks back (e.g. the screen bubble reading content aloud).
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Voice: alloy, ash, coral, echo, fable, nova, onyx, sage, shimmer, ...
TTS_VOICE=alloy
# Output: mp3 (default), opus, aac, flac, wav, pcm
TTS_FORMAT=mp3

# Headers OpenRouter uses for attribution/ranking. Override for production so
# the OpenRouter dashboard shows YOUR real app, not the placeholder.
OPENROUTER_APP_URL=https://tailzu.space
OPENROUTER_APP_NAME=Tulmi

# Prompt versions loaded from shared/prompts/. Override only when shipping
# a new variant (a/b testing); empty falls back to the defaults v2/v1.
CLEANUP_PROMPT_VERSION=v2
REPLY_PROMPT_VERSION=v1

# --- Supabase (auth + usage metering) ---
# Project settings → API. URL is public; the SERVICE ROLE key is SECRET
# (server-side only, never ship it to the app).
SUPABASE_URL=
# The anon/public key signs users in on the app AND lets this backend VERIFY
# their JWTs (verifying a token only calls /auth/v1/user). So real auth works
# with just URL + ANON key — no service key required.
SUPABASE_ANON_KEY=
# The SERVICE ROLE key is only needed to WRITE usage metering (bypasses RLS).
# Optional: without it, auth still works and metering just logs instead.
SUPABASE_SERVICE_KEY=

# --- Server ---
PORT=8080
HOST=0.0.0.0
# Set to "production" on the VPS — the server refuses to boot with
# DEV_SKIP_AUTH=true under NODE_ENV=production (cost-amplification guard).
NODE_ENV=production

# --- Rate limiting ---
# Per-IP / per-Authorization caps applied across /v1/* routes.
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
# Tighter cap on routes that accept unauthenticated requests (bootstrap, screen,
# keyboard/config). Tune up if your SDUI shell needs more headroom.
RATE_LIMIT_UNAUTH_MAX=20

# Set to "true" ONLY for local pipeline testing — every request is mapped to
# a stub user. The server REFUSES to boot if true AND NODE_ENV=production
# (override with DEV_SKIP_AUTH_ALLOW_PROD=true at your own risk).
DEV_SKIP_AUTH=false
